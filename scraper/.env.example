# =============================================================================
# Local Research Agent — environment variables
# Copy to ".env" (same folder) and fill in. NEVER commit the real .env.
# =============================================================================

# ---- Supabase (REQUIRED) ----------------------------------------------------
# The agent runs locally and uses the SERVICE ROLE key so it can write data and
# bypass RLS. Keep this key on your PC only — it must never reach the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- AI extraction layer ----------------------------------------------------
# Order of preference: Ollama (local) -> OpenAI -> Anthropic.
# Set AI_PROVIDER to force one, or leave 'auto' to try in that order.
AI_PROVIDER=auto                       # auto | ollama | openai | anthropic | none

# Ollama (local, free). Set OLLAMA_MODEL to any model from `ollama list`.
# qwen2.5:72b = best quality + clean JSON; qwen3:14b = faster fallback.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b

# OpenAI fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude fallback (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Scheduler --------------------------------------------------------------
# Time of day (24h, local) for the daily automatic crawl when running
# `python -m agent.main schedule`.
DAILY_RUN_TIME=03:00
# How often (seconds) the scheduler checks Supabase for admin-queued manual runs.
QUEUE_POLL_SECONDS=30

# ---- Crawler defaults (overridable per-source in the DB) --------------------
DEFAULT_RATE_LIMIT=2.0                  # seconds between requests
HTTP_TIMEOUT=30                         # per-request timeout (seconds)
MAX_RETRIES=3                           # retry attempts on transient failures
USER_AGENT=ResearchAgent/1.0 (+local research aggregator; contact: you@example.com)

# ---- Dedup ------------------------------------------------------------------
FUZZY_TITLE_THRESHOLD=90                # 0-100; higher = stricter duplicate match

# ---- Whole Foods collector --------------------------------------------------
WFM_STORE_ID=10291                      # 10291 = Portland, ME (see /api/stores/<id>/summary)
WFM_POSTAL_CODE=04101

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
