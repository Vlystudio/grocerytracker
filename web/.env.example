# =============================================================================
# Next.js dashboard environment — copy to ".env.local" and fill in.
#
# IMPORTANT: only the ANON (public) key goes here. NEVER put the Supabase
# service-role key in the website — it would be exposed to browsers.
# =============================================================================

# Public values (safe to expose to the browser — NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
